        {
            "parameters": {
                "jsCode": "const inputs = $input.all();\nconst payload = items[0].json.body;\n\n// Na prática do n8n (encadeado ou Set), aqui combinaríamos os outputs.\n// Como é um mock/planejamento, consolidamos os dados.\n\nreturn [\n  {\n    json: {\n      sucesso: true,\n      docxtemplater: {\n        numero_processo: payload.numero_processo || \"N/A\",\n        objeto_contratacao: payload.objeto_contratacao || \"N/A\",\n        is_bens_comuns: $('Agente 2: Requisitos Licitatórios').item.json.is_bens_comuns || true,\n        itens: $('Agente 1: Especificações e Custos').item.json.itens || []\n      },\n      frontend_preview: {\n        secao_gestao: $('Agente 3: Riscos e Fiscalização').item.json.secao_gestao_texto_preview || \"\",\n        secao_requisitos: $('Agente 2: Requisitos Licitatórios').item.json.secao_requisitos_texto_preview || \"\"\n      }\n    }\n  }\n];"
            },
