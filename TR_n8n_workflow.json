        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Atue como um Especialista Jurídico em Licitações (Lei 14.133).\nLeia as respostas do usuário e o ETP.\n\nRetorne EXATAMENTE este JSON:\n{\n  \"is_bens_comuns\": true/false,\n  \"is_bens_especiais\": true/false,\n  \"aceita_subcontratacao\": true/false,\n  \"exige_amostra\": true/false,\n  \"secao_requisitos_texto_preview\": \"# Requisitos de Habilitação\\n...\"\n}",
                "hasOutputParser": true
            },
