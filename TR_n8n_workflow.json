        {
            "parameters": {
                "promptType": "define",
                "text": "=Atue como um Gestor de Riscos e Fiscalização de Contratos (Lei 14.133).\nAnalise a MATRIZ DE RISCOS recebida.\n\nRetorne ESTRITAMENTE este JSON:\n{\n  \"prazo_garantia\": \"...\",\n  \"tem_garantia_contratual\": true/false,\n  \"secao_gestao_texto_preview\": \"# Modelo de Gestão\\n...\",\n  \"secao_infracoes_texto_preview\": \"# Infrações e Sanções\\n...\"\n}",
